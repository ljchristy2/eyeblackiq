# EyeBlackIQ — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ── Odds APIs ──────────────────────────────────
ODDS_API_KEY=
THERUNDOWN_API_KEY=

# ── Sports Data ────────────────────────────────
APISPORTS_KEY=

# ── Weather ────────────────────────────────────
VISUAL_CROSSING_KEY=
OPENWEATHER_API_KEY=

# ── Twitter / X ────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_ENABLED=false

# ── Site ───────────────────────────────────────
SITE_URL=https://eyeblackiq.github.io

# ── Database ───────────────────────────────────
DB_PATH=pipeline/db/eyeblackiq.db

# ── Model parameters ───────────────────────────
MIN_EDGE_PCT=0.02
KELLY_FRACTION=0.25
BANKROLL_MAX_PCT=0.03
SLIPPAGE_CENTS=10

# ── Logging ────────────────────────────────────
LOG_LEVEL=INFO

# ── GitHub ─────────────────────────────────────
GH_TOKEN=
